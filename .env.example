# Project name (used as container prefix: trd-mariadb, trd-web, trd-bot, etc.)
COMPOSE_PROJECT_NAME=trd
TZ=UTC

WEB_PORT=8088
WEB_PUBLISH_IP=127.0.0.1
MARIADB_PORT=3306

MARIADB_ROOT_PASSWORD=root_change_me
MARIADB_ROOT_SOCKET_AUTH=1
MARIADB_ROOT_PASSWORD_FILE=/var/secrets/mariadb_root_password
MARIADB_DATABASE=trading
MARIADB_USER=trading
MARIADB_PASSWORD=trading_change_me
TRADING_DB_PASSWORD=trading_change_me
MARIADB_SERVER_ID=1
MARIADB_BINLOG_EXPIRE_SECONDS=259200
MARIADB_RELAY_LOG_SPACE_LIMIT=1073741824
MARIADB_BACKUP_ON_START=1
MARIADB_BACKUP_RETENTION_DAYS=7
MARIADB_BACKUP_DIR=/var/backup/mysql
MARIADB_BACKUP_PING_TIMEOUT_SECONDS=60
MARIADB_ERROR_LOG=/var/log/mysql/mysql.log
MARIADB_REPL_USER=repl
MARIADB_REPL_PASSWORD=repl_change_me
MARIADB_REMOTE_USER=
MARIADB_REMOTE_PASSWORD=
MARIADB_REMOTE_DB=trading
PRIMARY_HOST=10.0.0.1
PRIMARY_PORT=3306
WATCHDOG_INTERVAL_SECONDS=15
MARIADB_MAX_REPL_LAG_SECONDS=300

BOT_IMPL_NAME=bitmex_bot

SIGNALS_API_URL=http://host.docker.internal
WEB_DOCROOT=/app/src/web-ui
WEB_BIND_HOST=0.0.0.0
WEB_BIND_PORT=80
MYSQL_ERROR_LOG_PATH=/app/var/log/mysql/mysql.log

# Auth mode levels:
#  basic    -> primitive ip_check/auth_check flow, no Telegram rights lookup
#  telegram -> rights resolved from x-user-id via TRADEBOT_PHP_HOST/get_user_rights.php
AUTH_MODE=basic
TRADEBOT_PHP_HOST=http://localhost
ALLOW_LOCAL_ADMIN_BYPASS=0
ADMIN_IP_ALLOWLIST=127.0.0.1,::1
OTP_MODE=on
OTP_CONFIG_FILE=/app/var/data/admin_otp.php
OTP_TTL_SECONDS=900
BINLOG_WARN_BYTES=1073741824
RELAY_WARN_BYTES=1073741824

# Used only by bot-manager profile.
PASS_STORE_DIR=./secrets/pass-store
GPG_HOME_DIR=./secrets/gnupg

# bot-manager credential mode:
#   pass -> read credentials from pass store
#   db   -> read API creds from DB config params and trader password from BOT_TRADER_PASSWORD
BOT_CREDENTIAL_SOURCE=pass

# pass encryption mode:
#   none       -> pass store readable without interactive gpg unlock
#   encrypted  -> wait for gpg-agent/unlock before startup
BOT_PASS_ENCRYPTION_MODE=none

# Startup synchronization for encrypted pass mode.
BOT_GPG_WAIT_ENABLED=1
BOT_GPG_WAIT_TIMEOUT_SECONDS=180
BOT_GPG_WAIT_INTERVAL_SECONDS=2
BOT_GPG_PROBE_PATH=users/trader
BOT_GPG_PROBE_PATHS=users/trader

# Required when BOT_CREDENTIAL_SOURCE=db.
BOT_TRADER_PASSWORD=

# DB param names for API credentials (per account config table).
BOT_DB_API_KEY_PARAM=api_key
BOT_DB_API_SECRET_PARAM=api_secret

# Deployment helper can clone missing runtime libs from this repo.
ALPET_LIBS_REPO=P:/GitHub/alpet-libs-php
